{
  "version": 2,
  "buildCommand": "bash melon_ticket_app/scripts/vercel-build.sh",
  "outputDirectory": "melon_ticket_app/build/web",
  "rewrites": [
    {
      "source": "/m/:token",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(kakaotalk|facebookexternalhit|Twitterbot|Slackbot|LinkedInBot|Googlebot|bot|crawler|spider).*"
        }
      ],
      "destination": "https://us-central1-melon-ticket-mvp-2026.cloudfunctions.net/getTicketOgMeta?token=:token&format=html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(flutter_bootstrap.js|main.dart.js|flutter_service_worker.js|version.json)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
